<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Safari Adventure Park</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- MAIN BANNER -->
    <div style="position: relative;">
        <img src="/images/choice/imagebanner5.png" alt="Safari Adventure Park" width="100%" style="max-height: 600px; object-fit: cover; display: block;">
        <div style="position: absolute; bottom: 40px; left: 50px;">
            <h1 style="color: white; font-size: 3em; margin: 0; text-shadow: 2px 2px 8px black;">Safari Adventure Park</h1>
            <p style="color: white; font-size: 1.3em; margin: 0; text-shadow: 1px 1px 6px black;">Explore. Protect. Connect.</p>
        </div>
    </div>
    
    <!-- ZONES CAROUSEL -->
<div class="carousel-container">
    <button class="carousel-btn left" onclick="moveCarousel(-1)">&#8249;</button>

    <div class="carousel-track">
        <div class="carousel-item" data-index="0">
            <a href="/outback">
                <img src="/images/choice/australianoutback/australianoutback3.png" alt="Australian Outback">
                <p>Australian Outback</p>
            </a>
        </div>
        <div class="carousel-item active" data-index="1">
    <a href="/savannah">

                <img src="/images/choice/savannah/savannahplains1.png" alt="Savannah Plains">
                <p>Savannah Plains</p>
            </a>
        </div>
        <div class="carousel-item" data-index="2">
            <a href="/reptile">
                <img src="/images/choice/reptile/reptileword5.png" alt="Reptile World">
                <p>Reptile World</p>
            </a>
        </div>
        <div class="carousel-item" data-index="3">
            <a href="/rainforest">
                <img src="/images/choice/rainforest/rainforestcanopy3.png" alt="Rainforest Canopy">
                <p>Rainforest Canopy</p>
            </a>
        </div>
    </div>

    <button class="carousel-btn right" onclick="moveCarousel(1)">&#8250;</button>
</div>


